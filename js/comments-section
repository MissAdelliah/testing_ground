function createCommentCard(comment) {
  const article = document.createElement('article');
  article.className = 'comment-card';

  article.innerHTML = `
    <p class="comment-text">${comment.text}</p>
    <div class="comment-footer">
      <img class="comment-avatar" src="${comment.avatar}" alt="${comment.name}">
      <div class="comment-meta">
        <span class="comment-name">${comment.name}</span>
        <span class="comment-handle">${comment.handle}</span>
      </div>
    </div>
  `;

  return article;
}

function renderTrack(trackElement, comments) {
  const fragment = document.createDocumentFragment();

  comments.forEach((comment) => {
    fragment.appendChild(createCommentCard(comment));
  });

  comments.forEach((comment) => {
    fragment.appendChild(createCommentCard(comment));
  });

  trackElement.appendChild(fragment);
  trackElement.dataset.ready = 'true';
}

function splitCommentsIntoRows(comments) {
  const topRow = [];
  const bottomRow = [];

  comments.forEach((comment, index) => {
    if (index % 2 === 0) {
      topRow.push(comment);
    } else {
      bottomRow.push(comment);
    }
  });

  return { topRow, bottomRow };
}

function revealCardsOnLoad() {
  const cards = document.querySelectorAll('.comment-card');

  cards.forEach((card, index) => {
    setTimeout(() => {
      card.classList.add('is-visible');
    }, 70 * index);
  });
}

function initCommentsSection() {
  const trackTop = document.getElementById('trackTop');
  const trackBottom = document.getElementById('trackBottom');

  if (!trackTop || !trackBottom) return;

  const { topRow, bottomRow } = splitCommentsIntoRows(commentsData);

  renderTrack(trackTop, topRow);
  renderTrack(trackBottom, bottomRow);

  revealCardsOnLoad();
}

document.addEventListener('DOMContentLoaded', initCommentsSection);
